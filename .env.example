# ============================================================
# ADK Prior Authorization Agent — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
#
# Local dev setup:
#   1. Copy: cp .env.example .env  (or copy manually in Windows)
#   2. Fill in values below
#   3. Run: gcloud auth application-default login
#   4. Run: gcloud config set project healthcare-sa-2026
# ============================================================

# ── GCP Project ──────────────────────────────────────────────
GCP_PROJECT_ID=healthcare-sa-2026
GCP_REGION=us-central1

# ── FHIR Store ───────────────────────────────────────────────
# These three values combine to form the Healthcare API URL.
# Format: projects/{project}/locations/{location}/datasets/{dataset}/fhirStores/{store}
FHIR_DATASET=cdss-dataset
FHIR_DATASTORE=cdss-fhir-store
FHIR_LOCATION=us-central1

# ── Gemini ───────────────────────────────────────────────────
GEMINI_MODEL=gemini-2.5-flash

# ── Payer API (Availity fallback) ────────────────────────────
AVAILITY_BASE_URL=https://api.availity.com/availity/v1

# ── Firestore Cache ──────────────────────────────────────────
# How long to cache payer questionnaires (hours)
DTR_CACHE_TTL_HOURS=24

# ── PA Polling ───────────────────────────────────────────────
# How often to poll payer for decision (minutes)
PAS_POLL_INTERVAL_MINUTES=15

# ── Cloud DLP ────────────────────────────────────────────────
DLP_TEMPLATE=cdss-phi-doc-agents

# ── CDI Confidence Threshold ─────────────────────────────────
CDI_CONFIDENCE_THRESHOLD=0.75